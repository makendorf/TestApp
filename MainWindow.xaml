<Window x:Class="TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тестовое приложение" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2c3e50" Padding="10">
            <StackPanel>
                <TextBlock Text="Меню" Foreground="White" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <Button Content="Сотрудники" Command="{Binding ShowEmployeesCommand}"
                        Padding="10" Margin="0,5" HorizontalContentAlignment="Left"
                        Background="#34495e" Foreground="White" BorderThickness="0"/>
                <Button Content="Контрагенты" Command="{Binding ShowCounterpartiesCommand}"
                        Padding="10" Margin="0,5" HorizontalContentAlignment="Left"
                        Background="#34495e" Foreground="White" BorderThickness="0"/>
                <Button Content="Заказы" Command="{Binding ShowOrdersCommand}"
                        Padding="10" Margin="0,5" HorizontalContentAlignment="Left"
                        Background="#34495e" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="10"/>
    </Grid>
</Window>
