<UserControl x:Class="TestApp.Views.EmployeeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:TestApp.Models.Enums">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Сотрудники" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Employees}" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                  SelectedItem="{Binding SelectedEmployee}" AlternatingRowBackground="#f5f5f5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="120"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=d}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Center">
            <Button Content="Добавить" Command="{Binding AddCommand}" Padding="15,8" Margin="5,0"/>
            <Button Content="Редактировать" Command="{Binding EditCommand}" Padding="15,8" Margin="5,0"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" Padding="15,8" Margin="5,0"/>
        </StackPanel>

        <Border Grid.Row="0" Grid.RowSpan="3" Background="White" Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                Padding="20" Margin="50">
            <StackPanel MaxWidth="400" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Данные сотрудника" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="ФИО:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Должность:" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding PositionValues}" SelectedItem="{Binding Position}"
                          Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Дата рождения:" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding BirthDate}" Margin="0,0,0,15"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Сохранить" Command="{Binding SaveCommand}" Padding="15,8" Margin="5,0"/>
                    <Button Content="Отмена" Command="{Binding CancelCommand}" Padding="15,8" Margin="5,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
